{
  "name": "peerkit",
  "version": "0.1.0",
  "description": "Peer-to-peer data synchronization framework",
  "keywords": [
    "p2p",
    "peer-to-peer",
    "data",
    "sync"
  ],
  "author": "dev-team@holochain.org",
  "license": "CAL-1.0",
  "private": true,
  "bugs": {
    "url": "https://github.com/holochain/peerkit/issues"
  },
  "homepage": "https://github.com/holochain/peerkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holochain/peerkit.git"
  },
  "directories": {
    "doc": "docs"
  },
  "workspaces": [
    "packages/transport-libp2p-core",
    "packages/transport-libp2p-nodejs",
    "packages/transport-libp2p-react-native",
    "packages/transport-libp2p",
    "packages/api",
    "packages/agent-store"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "lint": "eslint",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "test": "npm test --workspaces",
    "build:docs": "typedoc",
    "build:dist": "tsc --build",
    "build": "npm run build:dist && npm run build:docs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.5",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0"
  }
}
