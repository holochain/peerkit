{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "es2024",
    "types": ["node"],

    // Project References
    "composite": true,

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,

    // Recommended Options
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "files": [],
  "references": [
    { "path": "packages/transport-libp2p-core" },
    { "path": "packages/transport-libp2p-nodejs" },
    { "path": "packages/transport-libp2p-react-native" },
    { "path": "packages/transport-libp2p" },
    { "path": "packages/api" },
    { "path": "packages/agent-store" }
  ]
}
